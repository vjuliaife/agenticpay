{
  "name": "agenticpay-backend",
  "version": "0.1.0",
  "description": "AgenticPay API server - AI verification & invoicing for Stellar payments",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "db:generate": "prisma generate",
    "db:migrate": "npx tsx migrations/runner.ts deploy",
    "db:migrate:status": "npx tsx migrations/runner.ts status",
    "db:rollback": "npx tsx migrations/runner.ts rollback",
    "db:rollback:one": "npx tsx migrations/runner.ts rollback-one",
    "db:migrate:check": "npx tsx migrations/runner.ts check",
    "db:reset": "npx tsx migrations/runner.ts reset",
    "db:seed": "npx tsx migrations/runner.ts seed",
    "db:studio": "prisma studio",
    "openapi:generate": "tsx scripts/generate-openapi.ts",
    "openapi:validate": "node -e \"require('fs').accessSync('docs/api/openapi/openapi.json')\"",
    "sdk:generate": "npm run openapi:generate && tsx ../sdk-generator/dist/cli.js --config openapi.config.json",
    "sdk:generate:typescript": "npm run openapi:generate && tsx ../sdk-generator/dist/cli.js --config openapi.config.json --lang typescript",
    "sdk:generate:python": "npm run openapi:generate && tsx ../sdk-generator/dist/cli.js --config openapi.config.json --lang python",
    "sdk:generate:go": "npm run openapi:generate && tsx ../sdk-generator/dist/cli.js --config openapi.config.json --lang go",
    "sdk:generate:rust": "npm run openapi:generate && tsx ../sdk-generator/dist/cli.js --config openapi.config.json --lang rust",
    "benchmark": "tsx src/tests/benchmarks/run-benchmarks.ts",
    "benchmark:baseline": "tsx src/tests/benchmarks/run-benchmarks.ts --write-baseline",
    "benchmark:compare": "tsx src/tests/benchmarks/compare-baseline.ts",
    "generate:vapid-keys": "node scripts/generate-vapid-keys.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^10.50.0",
    "@sentry/profiling-node": "^10.50.0",
    "@stellar/stellar-sdk": "^12.0.0",
    "bullmq": "^5.77.6",
    "circomlib": "^2.0.5",
    "circomlibjs": "^0.1.7",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "cron-parser": "^4.9.0",
    "dompurify": "^3.0.6",
    "dotenv": "^16.4.5",
    "escape-html": "^1.0.3",
    "ethers": "^6.16.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.11.0",
    "node-cron": "^3.0.3",
    "openai": "^4.67.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "qrcode": "^1.5.3",
    "sanitize-html": "^2.11.0",
    "snarkjs": "^0.7.6",
    "speakeasy": "^2.0.0",
    "sqlstring": "^2.3.3",
    "stripe": "^17.5.0",
    "validator": "^13.11.0",
    "viem": "^2.43.2",
    "web-push": "^3.6.0",
    "ws": "^8.18.0",
    "xss": "^1.0.14",
    "zod": "^3.23.8"
  },
  "prisma": {
    "seed": "tsx migrations/seed.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/circomlibjs": "^0.1.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/dompurify": "^3.0.3",
    "@types/escape-html": "^1.0.2",
    "@types/express": "^5.0.0",
    "@types/express-rate-limit": "^5.1.3",
    "@types/node": "^22.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/sanitize-html": "^2.9.0",
    "@types/snarkjs": "^0.7.9",
    "@types/speakeasy": "^2.0.8",
    "@types/validator": "^13.11.6",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.5.12",
    "eslint": "^9.0.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.1",
    "autocannon": "^7.15.0",
    "openapi-fetch": "^0.13.5",
    "openapi-typescript": "^7.4.4",
    "pino-pretty": "^13.0.0"
  }
}
